# ============================================
# Question Lab - File .gitignore
# ============================================

# Database e dati utente (NON tracciare)
database.json
categories.json
preferences.json

# Log e backup utente
databases/
update_log.json

# Backup pre-aggiornamento app
update_backups/

# File di log
*.log

# Python - File compilati e cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Python - Ambienti virtuali
venv/
.venv/
env/
.env/
ENV/

# Python - Distribuzione
build/
dist/
*.egg-info/
*.egg

# Python - IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Python - Testing
.pytest_cache/
.coverage
htmlcov/

# OS - Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# OS - macOS
.DS_Store
.AppleDouble
.LSOverride

# OS - Linux
*~
.fuse_hidden*
.directory
.Trash-*

# Temp file
*.tmp
*.temp

# File di configurazione locale (se contiene dati sensibili)
# .env

# Export generati dall'utente
*.docx
*.pdf

# Documentazione locale
istruzioni.txt
test_categories_features.py
CATEGORIES_ADVANCED_FEATURES.md
FLAG_FEATURE_PLAN.md
docs/

# File
.qwen/
.kilo/