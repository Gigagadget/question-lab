{
  "github_repo": "https://github.com/Gigagadget/question-lab",
  "github_api": "https://api.github.com/repos/Gigagadget/question-lab",
  "branch": "master",
  "protected_files": [
    "version.json",
    "config.json"
  ],
  "protected_dirs": [
    "databases",
    "update_backups"
  ],
  "update_settings": {
    "max_retries": 3,
    "timeout_seconds": 30,
    "allow_prerelease": false
  },
  "lan_password_enabled": true,
  "log_failed_auth": false,
  "search": {
    "mode": "normal",
    "highlightEnabled": true,
    "searchAnswers": true,
    "searchNotes": true,
    "searchCategories": true,
    "minScore": 15
  }
}